    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "id",
          "value": "claude-haiku-4-5-20251001"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a project management assistant. \nExtract task information from this support email and return ONLY valid JSON.\n\nEmail content: {{ $('Email Trigger (IMAP)').first().json.textPlain || $('Email Trigger (IMAP)').first().json.textHtml }}\nSubject: {{ $('Email Trigger (IMAP)').first().json.metadata['thread-topic'] }}\nSender: {{ $('Email Trigger (IMAP)').first().json.metadata['return-path'] }}\n\nReturn this exact JSON structure:\n{\n  \"title\": \"short task title (max 60 chars)\",\n  \"description\": \"detailed description of the request\",\n  \"prio\": \"urgent OR medium OR low\",\n  \"dueDate\": \"YYYY-MM-DD (7 days from today if not specified)\",\n  \"category\": \"Technical Task OR User Story\",\n  \"createdBy\": \"sender email address\"\n}\n"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        16,
        -384
      ],
      "id": "29207fd4-3dc2-411e-a8d3-f0cf128b3847",
      "name": "Message a model",
      "credentials": {
        "anthropicApi": {
          "id": "QEgszQfqwqanplD3",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().slice(0, 10);\nconst aiOutput = $input.first().json;\nconst raw = aiOutput?.message?.content?.[0]?.text \n         || aiOutput?.content?.[0]?.text \n         || aiOutput?.text || '';\n\nconst jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) throw new Error('No JSON found in AI response');\n\nconst parsed = JSON.parse(jsonMatch[0]);\n\nconst badTitle = !parsed.title \n    || parsed.title.toLowerCase().includes('no email')\n    || parsed.title.toLowerCase().includes('unable to extract')\n    || parsed.title.toLowerCase().includes('not provided')\n    || parsed.title.trim().length < 3;\nif (badTitle) throw new Error('Empty email — skipping task creation');\n\nif (!parsed.dueDate || parsed.dueDate < today) {\n    parsed.dueDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);\n}\n\nconst emailData = $('Email Trigger (IMAP)').first().json;\nconst from = emailData.from;\nlet fromText = '';\nif (typeof from === 'string') { fromText = from; }\nelse { fromText = from?.text || from?.value?.[0]?.name || from?.value?.[0]?.address || ''; }\n\nconst nameMatch = fromText.match(/^([^<]+)</);\nif (nameMatch) { parsed.createdByName = nameMatch[1].trim(); }\nelse if (fromText.includes('@')) { parsed.createdByName = fromText.split('@')[0]; }\nelse { parsed.createdByName = fromText || ''; }\n\n// Fallback: return-path aus Outlook metadata\nconst returnPath = emailData.metadata?.['return-path'] || '';\nparsed.createdBy = from?.value?.[0]?.address \n                || fromText.match(/[\\w.-]+@[\\w.-]+\\.\\w+/)?.[0]\n                || returnPath.replace(/[<>]/g, '').trim()\n                || '';\n\nreturn [{ json: parsed }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        -384
      ],
      "id": "0d7fabfd-2630-4ea6-80c3-06c05a79af01",
      "name": "Extract Fields"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://firestore.googleapis.com/v1/projects/join-c7e60/databases/(default)/documents/triage_tasks",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"fields\": {\n    \"title\": { \"stringValue\": \"{{ $json.title }}\" },\n    \"description\": { \"stringValue\": \"{{ $json.description }}\" },\n    \"dueDate\": { \"stringValue\": \"{{ $json.dueDate }}\" },\n    \"category\": { \"stringValue\": \"{{ $json.category }}\" },\n    \"prio\": { \"stringValue\": \"{{ $json.prio }}\" },\n    \"status\": { \"stringValue\": \"triage\" },\n    \"subtasks\": { \"arrayValue\": { \"values\": [] } },\n    \"assignedContacts\": { \"arrayValue\": { \"values\": [] } },\n    \"createdBy\": { \"stringValue\": \"{{ $json.createdBy }}\" },\n    \"createdByName\": { \"stringValue\": \"{{ $json.createdByName }}\" },\n    \"creatorType\": { \"stringValue\": \"external\" },\n    \"aiGenerated\": { \"booleanValue\": true }\n  }\n}\n",
        "options": {}
