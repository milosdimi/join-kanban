    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().slice(0, 10);\nconst doc = $input.first().json;\nconst currentDate = doc.fields?.date?.stringValue || '';\nconst currentCount = parseInt(doc.fields?.count?.integerValue || 0);\nconst newCount = currentDate === today ? currentCount + 1 : 1;\nreturn [{ json: { count: newCount, date: today } }];\n"
      },
